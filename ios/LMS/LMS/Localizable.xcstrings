    "This resets the round so you can reselect fixtures. Any picks already made are cleared. This can't be undone.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies setzt die Runde zurück, damit du die Spiele neu auswählen kannst. Bereits getroffene Tipps werden gelöscht. Das kann nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto reinicia la ronda para que puedas volver a elegir los partidos. Las selecciones ya hechas se borran. Esto no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela réinitialise la manche pour que tu puisses resélectionner les matchs. Les choix déjà faits sont effacés. Action irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo azzera il turno così puoi riselezionare le partite. Le scelte già fatte vengono cancellate. L'operazione non può essere annullata."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit zet de ronde terug zodat je de wedstrijden opnieuw kunt kiezen. Reeds gemaakte keuzes worden gewist. Dit kan niet ongedaan worden gemaakt."
          }
        }
      }
    },

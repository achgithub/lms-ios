    "The game's done. Share the final result, and you're all set — start a new game whenever you like.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Spiel ist beendet. Teile das Endergebnis – fertig. Starte ein neues Spiel, wann immer du möchtest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La partida ha terminado. Comparte el resultado final y listo: empieza una nueva partida cuando quieras."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La partie est terminée. Partage le résultat final, et voilà — lance une nouvelle partie quand tu veux."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La partita è finita. Condividi il risultato finale e il gioco è fatto: inizia una nuova partita quando vuoi."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het spel is afgelopen. Deel de einduitslag en je bent klaar — start wanneer je wilt een nieuw spel."
          }
        }
      }
    },
    "Their team pool resets — all teams open again.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr Mannschafts-Pool wird zurückgesetzt – alle Mannschaften sind wieder verfügbar."
          }

        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Désactiver %@ supprime ses données de cet appareil et supprime %lld parties qui l’utilisent."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Disattivare %@ rimuove i suoi dati da questo dispositivo ed elimina %lld partite che la usano."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ uitschakelen verwijdert de gegevens van dit apparaat en wist %lld spellen die het gebruiken."
          }
        }
      }
    },

    "A game needs at least 2 players to start a round.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Spiel braucht mindestens 2 Spieler, um eine Runde zu starten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una partida necesita al menos 2 jugadores para empezar una ronda."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une partie nécessite au moins 2 joueurs pour lancer une manche."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Una partita richiede almeno 2 giocatori per iniziare un turno."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een spel heeft minstens 2 spelers nodig om een ronde te starten."

      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schaltet Werbung an/aus und das Liga-Kontingent ohne Kauf um. Kostenlos = 1 Liga; bezahlt = alle."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia con/sin anuncios y el número de ligas sin comprar. Gratis = 1 liga; de pago = todas."
          }
        },
        "fr": {
          "stringUnit": {

    "This permanently deletes %lld games and can't be undone.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden %lld Spiele dauerhaft gelöscht und können nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina %lld partidas de forma permanente y no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime définitivement %lld parties et est irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo elimina %lld partite in modo permanente e non può essere annullato."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiermee worden %lld spellen permanent verwijderd en dit kan niet ongedaan worden gemaakt."

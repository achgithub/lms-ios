          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ (jij)"
          }
        }
      }
    },
    "%@ is removed from the game and their picks deleted. This can't be undone.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ wird aus dem Spiel entfernt und die Tipps werden gelöscht. Das kann nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ se quita de la partida y se eliminan sus selecciones. Esto no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ est retiré de la partie et ses choix sont supprimés. Cette action est irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ viene rimosso dalla partita e le sue scelte vengono eliminate. Operazione irreversibile."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ wordt uit het spel verwijderd en hun keuzes worden gewist. Dit kan niet ongedaan worden gemaakt."
          }
        }
      }
    },

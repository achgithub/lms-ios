<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Attest environment. Driven by the APP_ATTEST_ENVIRONMENT build setting
	     so Debug/devicectl builds attest in "development" and Release (App Store/
	     TestFlight) in "production" — matching the Worker's APP_ATTEST_ENV. -->
	<key>com.apple.developer.app-attest.environment</key>
	<string>$(APP_ATTEST_ENVIRONMENT)</string>
</dict>
</plist>

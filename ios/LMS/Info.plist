<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Google Mobile Ads (AdMob) App ID. This is Google's official TEST App ID;
	     swap for the real AdMob App ID before release. The SDK requires this key
	     at launch or it crashes. Generated Info.plist keys (launch screen, scene
	     manifest, orientations) are merged in by GENERATE_INFOPLIST_FILE=YES. -->
	<key>GADApplicationIdentifier</key>
	<string>ca-app-pub-3940256099942544~1458002511</string>
	<!-- App Tracking Transparency: shown by AdConsent before ads start. Without
	     this key the ATT prompt cannot appear and ads stay non-personalized. -->
	<key>NSUserTrackingUsageDescription</key>
	<string>This lets us show you more relevant ads. You can keep using the app whichever you choose.</string>
	<!-- Export compliance: the app only uses standard encryption (HTTPS). Setting
	     this avoids the "missing compliance" prompt on every TestFlight upload.
	     Revisit if you add non-exempt cryptography. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- Brand wordmark font (splash + future headers), see docs/brand/style-guide.md.
	     Files live in LMS/Resources/Fonts/. -->
	<key>UIAppFonts</key>
	<array>
		<string>Montserrat-ExtraBold.ttf</string>
		<string>Montserrat-Black.ttf</string>
	</array>
</dict>
</plist>
